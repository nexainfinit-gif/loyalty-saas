# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Cron security
CRON_SECRET=your-cron-secret

# Google Wallet
GOOGLE_WALLET_ISSUER_ID=1234567890123456789
GOOGLE_WALLET_CLIENT_EMAIL=wallet@your-project.iam.gserviceaccount.com
GOOGLE_WALLET_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Apple Wallet (requires Apple Developer account)
# APPLE_PASS_TYPE_IDENTIFIER=pass.com.yourcompany.loyalty
# APPLE_TEAM_IDENTIFIER=XXXXXXXXXX
# APPLE_PASS_CERT_P12_BASE64=base64-encoded-p12-certificate
# APPLE_PASS_CERT_PASSPHRASE=your-certificate-passphrase
# APPLE_WWDR_PEM=base64-encoded-wwdr-g4-certificate

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
